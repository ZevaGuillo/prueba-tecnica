								"description": "ID de correlación para trazabilidad"
							}
						],
						"url": {
							"raw": "http://{{servidor}}:{{puerto_reportes}}/api/reportes?clienteId=CLI001&fechaInicio=2026-01-01&fechaFin=2026-12-31&page=0&size=20",
